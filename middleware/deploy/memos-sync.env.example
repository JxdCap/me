MEMOS_SYNC_TOKEN=replace-with-your-ios-token
POCKETBASE_URL=https://a.ithe.cn
POCKETBASE_COLLECTION=memos
MEMOS_CATEGORIES=风景,碎语,吐槽,分享
POCKETBASE_TIMEOUT_SECONDS=300
MEMOS_MAX_UPLOAD_MB=300
MEMOS_MAX_MEDIA_FILES=9

# Choose one PocketBase auth method.
# Recommended: use a fixed PocketBase token if you already have one.
POCKETBASE_TOKEN=

# Or use PocketBase account/password auth.
POCKETBASE_EMAIL=
POCKETBASE_PASSWORD=
